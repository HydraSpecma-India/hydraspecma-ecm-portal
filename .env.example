# =============================================================================
# HydraSpecma ECM Portal — Environment Variables (copy to .env.local, never commit .env*)
# =============================================================================

# ---- Supabase (client-safe: exposed to the browser) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key

# ---- Supabase (server-only: Edge Functions / API routes) ----
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key
SUPABASE_JWT_SECRET=YOUR-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-ref.supabase.co:5432/postgres

# ---- Azure AD / Microsoft 365 SSO (Module 3 & 13) ----
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=https://your-app.vercel.app/auth/callback
MS_GRAPH_SCOPES=User.Read Mail.Send Calendars.ReadWrite offline_access

# ---- Dynamics 365 F&O (Module 12) ----
D365_ENVIRONMENT_URL=https://YOUR-env.operations.dynamics.com
D365_TENANT_ID=
D365_CLIENT_ID=
D365_CLIENT_SECRET=
D365_ODATA_PATH=/data

# ---- Power BI (Module 14) ----
POWERBI_WORKSPACE_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# ---- AI Assistant (Module 15) ----
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-5

# ---- App ----
APP_BASE_URL=https://your-app.vercel.app
APP_ENV=development
